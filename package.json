{
  "name": "deckplating",
  "version": "0.6.0-beta",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "npm run test:tooling && npm run test:tenant-isolation",
    "test:tooling": "node --test tests/tooling.node.test.mjs tests/credential-codec.node.test.mjs tests/cursor-pagination.node.test.mjs",
    "test:database": "bash scripts/run-database-behavior-suite.sh",
    "test:database:behavior": "node scripts/database-behavior-check.mjs",
    "test:ui": "npm run build && npm --prefix setup-site run build && playwright test",
    "test:tenant-isolation": "node scripts/tenant-isolation-check.mjs",
    "test:integration:two-workspace": "node scripts/two-workspace-integration-check.mjs",
    "test:smoke:first-pilot": "node scripts/first-pilot-smoke-check.mjs",
    "validate": "npm test && npm run build && npm --prefix setup-site run build"
  },
  "dependencies": {
    "@netlify/functions": "^2.8.2",
    "@supabase/supabase-js": "^2.45.4",
    "idb": "^8.0.3",
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "pg": "^8.22.0",
    "typescript": "^5.6.2",
    "vite": "^6.4.3"
  }
}
